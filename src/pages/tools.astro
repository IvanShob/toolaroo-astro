---
import '../styles/global.css';
import ToolList from '../components/ToolList.jsx';
import SEO from '../components/SEO.astro';
import Layout from '../components/Layout.astro';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "All AI Tools - Toolaroo",
  "description": "Complete directory of AI tools across all categories",
  "url": "https://www.toolaroo.net/tools/"
};

const seoProps = {
  title: "All AI Tools Directory – Toolaroo",
  description: "Explore 105+ AI tools across 12 categories: writing, image, coding, video, social media, meetings & more. Find your perfect AI tool.",
  type: "website",
  schema: schemaData
};
---

<Layout title="All AI Tools" description="Complete AI tools directory" seoProps={seoProps}>
  <!-- Hero Section -->
  <section class="py-20 sm:py-32 pb-3 border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 leading-tight">
        All<span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"> AI Tools</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-600">105+ AI tools, tested and ranked. Find the right tool for writing, coding, image generation, and more.</p>
    </div>
  </section>

  <!-- Tools Section -->
  <section class="py-8 sm:py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <ToolList client:load />
    </div>
  </section>

  <!-- Back to Top Button -->
  <button
    id="back-to-top"
    aria-label="Back to top"
    class="fixed bottom-8 right-8 z-50 w-12 h-12 bg-blue-600 hover:bg-blue-700 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 invisible transition-all duration-300"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>

  <script>
    const btn = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        btn.classList.remove('opacity-0', 'invisible');
        btn.classList.add('opacity-100', 'visible');
      } else {
        btn.classList.add('opacity-0', 'invisible');
        btn.classList.remove('opacity-100', 'visible');
      }
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
</Layout>
