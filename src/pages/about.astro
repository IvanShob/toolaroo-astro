---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Layout from '../components/Layout.astro';

const seoProps = {
  title: "About Toolaroo – AI Tools Directory",
  description: "Toolaroo is an independent AI tools directory. We test, review, and rank 105+ tools across 12 categories so you don't have to wade through marketing pages to find what actually works.",
  type: "website"
};
---

<Layout title="About Toolaroo" description="Learn about our mission" seoProps={seoProps}>
  <!-- Hero Section -->
  <section class="py-20 sm:py-32 pb-3 border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 leading-tight">
        About<span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"> Toolaroo</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-600">Independent reviews. No sponsored rankings. Just the tools that actually work.</p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-8 sm:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Mission -->
      <div class="mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">Our Mission</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-4">
          A new AI tool launches every day. Most of them are fine. A few are genuinely great. Finding out which is which usually means reading through marketing copy, watching demo videos, and signing up for free trials — for every single tool you're considering.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed">
          Toolaroo exists to cut through that. We test and review AI tools across 12 categories and tell you honestly what they're good at, what they're not, and who they're actually for. No sponsored rankings, no affiliate-driven "top 10" lists where the winner is whoever paid the most.
        </p>
      </div>

      <!-- What We Do -->
      <div class="mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">What We Do</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="p-6 bg-slate-50 rounded-xl border border-slate-200">
            <div class="text-3xl mb-3">🔍</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-2">Curate</h3>
            <p class="text-slate-600">We carefully select the best AI tools from hundreds of options and organize them by category.</p>
          </div>
          <div class="p-6 bg-slate-50 rounded-xl border border-slate-200">
            <div class="text-3xl mb-3">⚖️</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-2">Compare</h3>
            <p class="text-slate-600">Easily compare different AI tools to find the perfect match for your workflow and budget.</p>
          </div>
          <div class="p-6 bg-slate-50 rounded-xl border border-slate-200">
            <div class="text-3xl mb-3">✨</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-2">Discover</h3>
            <p class="text-slate-600">Find new and innovative AI tools that can transform the way you work and create.</p>
          </div>
        </div>
      </div>

      <!-- Categories -->
      <div class="mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">Our Categories</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          We cover 105+ tools across 12 categories — from everyday writing assistants to specialised tools for video production, meeting transcription, and social media:
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">✍️</div>
            <p class="font-semibold text-slate-900">Writing</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🎨</div>
            <p class="font-semibold text-slate-900">Image</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">💻</div>
            <p class="font-semibold text-slate-900">Coding</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🎬</div>
            <p class="font-semibold text-slate-900">Video</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🎵</div>
            <p class="font-semibold text-slate-900">Audio</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">⚡</div>
            <p class="font-semibold text-slate-900">Productivity</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🔬</div>
            <p class="font-semibold text-slate-900">Research</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🖼️</div>
            <p class="font-semibold text-slate-900">Design</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">📈</div>
            <p class="font-semibold text-slate-900">AI Marketing</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">📱</div>
            <p class="font-semibold text-slate-900">Social Media</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🎙️</div>
            <p class="font-semibold text-slate-900">Meetings</p>
          </div>
          <div class="p-4 bg-slate-100 rounded-lg text-center">
            <div class="text-2xl mb-2">🖥️</div>
            <p class="font-semibold text-slate-900">Presentations</p>
          </div>
        </div>
      </div>

      <!-- Why Choose Us -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">Why Choose Toolaroo?</h2>
        <ul class="space-y-4">
          <li class="flex items-start gap-4">
            <span class="text-blue-600 text-xl mt-1">✓</span>
            <div>
              <strong class="text-slate-900">Honest Reviews:</strong>
              <p class="text-slate-600">We list the cons alongside the pros. Every tool page includes pricing, limitations, and who it's actually for — not just a sales pitch.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-blue-600 text-xl mt-1">✓</span>
            <div>
              <strong class="text-slate-900">Kept Up to Date:</strong>
              <p class="text-slate-600">AI moves fast. We update tool pages when features change, pricing shifts, or better alternatives emerge.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-blue-600 text-xl mt-1">✓</span>
            <div>
              <strong class="text-slate-900">Useful Comparisons:</strong>
              <p class="text-slate-600">Each tool page shows real alternatives with a clear reason why you might choose one over the other — not just a list of names.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-blue-600 text-xl mt-1">✓</span>
            <div>
              <strong class="text-slate-900">Always Free:</strong>
              <p class="text-slate-600">Toolaroo is free to use. No paywalled reviews, no subscription required to see ratings or pricing.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
